# CampDash — PRODUCTION env. Copy to .env on the server, fill secrets. Never commit the real .env.
CD_ENV=prod

# Set a strong DB password; docker-compose passes it to both Postgres and the API.
POSTGRES_PASSWORD=CHANGE_ME_STRONG
# (docker-compose overrides CD_DATABASE_URL to point at the db service automatically)

# Live ShadyBucks bank + your house account (real bucks land here per order).
CD_BANK_API_URL=https://bucks.shady.tel
CD_HOUSE_PAN=8997986672600085
CD_HOUSE_PIN=                       # blank on live — checkout charges the CUSTOMER's card+OTP

# Delivery fee (30%) and abuse limits (defaults are fine)
CD_DELIVERY_FEE_BPS=3000

# Email via Gmail SMTP (App Password — see notes)
CD_SMTP_HOST=smtp.gmail.com
CD_SMTP_PORT=587
CD_SMTP_USER=youraddress@gmail.com
CD_SMTP_PASSWORD=your16charapppassword
CD_MAIL_FROM=CampDash <youraddress@gmail.com>

# Security — REQUIRED in prod
CD_FERNET_KEY=                      # python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
CD_ADMIN_KEY=codedaycodeday12       # gates /admin (kept consistent across the event apps)
CD_CORS_ORIGINS=["https://campdash.fun"]
